# ── Green.Money ────────────────────────────────────────────
GBP_API_BASE=https://www.greenbyphone.com
GBP_CLIENT_ID=                      # SERVER. live Client_ID (provided off-channel)
GBP_API_PASSWORD=                   # SERVER. live API password (provided off-channel)
GBP_CLIENT_ID_SANDBOX=              # SERVER. once requested from Green support
GBP_API_PASSWORD_SANDBOX=           # SERVER. once requested from Green support
GBP_MOCK=true                       # 'true' in dev/CI so we never touch live

# ── Twilio ─────────────────────────────────────────────────
